{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "core:path:default",
    "fs:allow-write-text-file",
    "fs:allow-appdata-write",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$APPDATA/**" }
      ]
    }
  ]
}